#include <ArduinoJson.h>    
#include <WiFi.h>    
#include <PubSubClient.h>   
#include <ESP32Servo.h> 
#include <LiquidCrystal_I2C.h>

LiquidCrystal_I2C lcd(0x27, 16, 2);

const char* ssid = "Wokwi-GUEST";  
const char* password = ""; 
const char* mqtt_server = "157.230.214.127"; 

WiFiClient espClient;               
PubSubClient client(espClient);     

// DECLARACIÓN DE LOS DOS SERVOS
Servo servoGatoA;
Servo servoGatoB;

String sr2 = "";                    
String inputString = "";            
char rec[50];                       

void setup() {
  pinMode(2, OUTPUT); // LED indicador de actividad

  // Configuración de frecuencias y pines para ambos servos
  servoGatoA.setPeriodHertz(50);
  servoGatoA.attach(13, 500, 2400); // Servo A en Pin 13

  servoGatoB.setPeriodHertz(50);
  servoGatoB.attach(12, 500, 2400); // Servo B en Pin 12 (NUEVO)

  // Posición inicial: Ambos platos cerrados (45 grados)
  servoGatoA.write(45);
  servoGatoB.write(45);

  Serial.begin(115200);                    
  setup_wifi();                            
  client.setServer(mqtt_server, 1883);     
  client.setCallback(callback);            

  lcd.init();
  lcd.backlight();
  lcd.setCursor(0,0);
  lcd.print("Comederos:");
  lcd.setCursor(0,1);
  lcd.print("Esperando michis");
}

void setup_wifi() {
  delay(10);                              
  Serial.println();                       
  Serial.print("Conectando a ");          
  Serial.println(ssid);                   
  WiFi.begin(ssid, password);             

  while (WiFi.status() != WL_CONNECTED) { 
    delay(500);                           
    Serial.print(".");                    
  }
  Serial.println("\nWiFi conectada");       
}

void reconnect() {                                   
  while (!client.connected()) {                      
    Serial.print("Esperando Conexión MQTT...");
    if (client.connect("unclientemas2910495")) {                
      Serial.println("conectado");                        
      client.subscribe("cmqtt_sdesi");           
    } else {                                               
      Serial.print("falla, rc=");                            
      Serial.print(client.state());                          
      Serial.println(" Intento de nuevo en 5 segundos");      
      delay(5000);                                           
    }
  }
}

void loop() {
  if (!client.connected()) {                                  
    reconnect();                                                 
  }
  client.loop();                                             
}

// LÓGICA DE CONTROL DE LOS COMEDEROS INDEPENDIENTES
void callback(char* topic, byte* payload, unsigned int length) {
  sr2 = "";
  for (int i = 0; i < length; i++) {
    rec[i] = payload[i];
    sr2 += rec[i];
    inputString = sr2;
  }

  char msg2[inputString.length() + 1];
  inputString.toCharArray(msg2, inputString.length() + 1);
  
  StaticJsonDocument<200> doc2;
  DeserializationError error = deserializeJson(doc2, msg2);

  if (error) {
    Serial.print(F("deserializeJson() failed: "));
    Serial.println(error.f_str());
    return;
  }

  String value = doc2["Act1"];
  Serial.print("Comando recibido: ");
  Serial.println(value);
 
  // CASO 1: Aparece el Gato A
  if (value.equals("GATO_A")) {
    digitalWrite(2, HIGH);
    servoGatoA.write(145); // Abre plato A
    servoGatoB.write(45);  // Cierra plato B (Seguridad)

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("Michi A detectado");
    lcd.setCursor(0,1);
    lcd.print("Plato A: ABIERTO");
  }
  
  // CASO 2: Aparece el Gato B
  else if (value.equals("GATO_B")) {
    digitalWrite(2, HIGH);
    servoGatoA.write(45);  // Cierra plato A (Seguridad)
    servoGatoB.write(145); // Abre plato B

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("Michi B detectado");
    lcd.setCursor(0,1);
    lcd.print("Plato B: ABIERTO");
  }
  
  // CASO 3: No hay nadie en la cámara o la confianza es baja
  else if (value.equals("NADIE")) {
    digitalWrite(2, LOW);
    servoGatoA.write(45);  // Cierra plato A
    servoGatoB.write(45);  // Cierra plato B

    lcd.clear();
    lcd.setCursor(0,0);
    lcd.print("Zona Vacia");
    lcd.setCursor(0,1);
    lcd.print("Platos: CERRADOS");
  }
}
