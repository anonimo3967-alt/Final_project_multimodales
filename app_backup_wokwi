#include <ArduinoJson.h>    
#include <WiFi.h>           
#include <PubSubClient.h>   
#include <ESP32Servo.h>     
#include <LiquidCrystal_I2C.h> 

LiquidCrystal_I2C lcd(0x27, 16, 2);

const char* ssid = "Wokwi-GUEST";  
const char* password = ""; 
const char* mqtt_server = "157.230.214.127"; 

WiFiClient espClient;               
PubSubClient client(espClient);     

Servo servoCoco;   // Servo en Pin 13
Servo servoCanela; // Servo en Pin 12

String sr2 = "";                    
String inputString = "";            
char rec[50];                       

unsigned long ultimoIntentoReconexion = 0;

void setup() {
  pinMode(2, OUTPUT); 

  servoCoco.setPeriodHertz(50);
  servoCoco.attach(13, 500, 2400); 

  servoCanela.setPeriodHertz(50);
  servoCanela.attach(12, 500, 2400); 

  // Estado inicial de seguridad
  servoCoco.write(45);
  servoCanela.write(45);

  Serial.begin(115200);                    
  setup_wifi();                            
  client.setServer(mqtt_server, 1883);     
  client.setCallback(callback); 

  lcd.init();
  lcd.backlight();
  lcd.setCursor(0, 0);
  lcd.print("Comederos:");
  lcd.setCursor(0, 1);
  lcd.print("Esperando michis");
}

void setup_wifi() {
  delay(10);                              
  Serial.println();                       
  Serial.print("Conectando a la red: ");          
  Serial.println(ssid);                   
  WiFi.begin(ssid, password);             

  while (WiFi.status() != WL_CONNECTED) { 
    delay(500);                           
    Serial.print(".");                    
  }
  Serial.println("\nWiFi Conectada");       
}

void reconnect() {
  if (!client.connected()) {
    unsigned long tiempoActual = millis();
    if (tiempoActual - ultimoIntentoReconexion >= 3000) {
      ultimoIntentoReconexion = tiempoActual;
      Serial.print("Intentando Conexión MQTT...");
      if (client.connect("esp32_michi_client_unique_9921")) {                
        Serial.println("¡Conectado!");                        
        client.subscribe("cmqtt_sdesi");           
      } else {                                               
        Serial.print("falla, rc=");                            
        Serial.println(client.state());                          
      }
    }
  }
}

void loop() {
  if (!client.connected()) {                                  
    reconnect();                                                 
  }
  client.loop(); 
}

// -------------------------------------------------------------------------
// REEVALUACIÓN DEL CALLBACK: PROCESAMIENTO SÍNCRONO UNIFICADO
// -------------------------------------------------------------------------
void callback(char* topic, byte* payload, unsigned int length) {
  sr2 = "";
  for (int i = 0; i < length; i++) {
    rec[i] = payload[i];
    sr2 += rec[i];
    inputString = sr2;
  }

  char msg2[inputString.length() + 1];
  inputString.toCharArray(msg2, inputString.length() + 1);
  
  StaticJsonDocument<200> doc2;
  DeserializationError error = deserializeJson(doc2, msg2);

  if (error) {
    Serial.print(F("Error deserializeJson(): "));
    Serial.println(error.f_str());
    return;
  }

  // Extraemos ambas variables que ahora viajan siempre juntas
  String gato_en_camara = doc2["Pantalla"];
  String comando_motores = doc2["Act1"];

  // 1. CONTROL SÍCRONO DE SERVOMOTORES
  if (comando_motores.equals("GATO_A")) {
    digitalWrite(2, HIGH);   
    servoCoco.write(145);    // Abre Coco
    servoCanela.write(45);   // Cierra Canela
    
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Orden por Voz:");
    lcd.setCursor(0, 1);
    lcd.print("Plato COCO: OPEN");
  }
  else if (comando_motores.equals("GATO_B")) {
    digitalWrite(2, HIGH);   
    servoCoco.write(45);     // Cierra Coco
    servoCanela.write(145);  // Abre Canela
    
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("Orden por Voz:");
    lcd.setCursor(0, 1);
    lcd.print("Plato CANELA:OPEN");
  }
  else if (comando_motores.equals("NADIE")) {
    digitalWrite(2, LOW);    
    servoCoco.write(45);     // Cierra Coco
    servoCanela.write(45);   // Cierra Canela

    // Si los motores están cerrados, la pantalla se dedica 100% a mostrar lo que ve la IA
    lcd.clear();
    lcd.setCursor(0, 0);
    lcd.print("IA Detecta:");
    lcd.setCursor(0, 1);
    
    if (gato_en_camara.equals("Coco")) {
      lcd.print("--> COCO ESPERA");
    } 
    else if (gato_en_camara.equals("Canela")) {
      lcd.print("--> CANELA ESPERA");
    } 
    else {
      lcd.print("Zona Vacia...");
    }
  }
}
